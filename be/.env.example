# Server
PORT=5000
NODE_ENV=development

# Solana
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Treasury Wallet (private key as a JSON byte array)
# Generate with: solana-keygen new --outfile treasury.json
# Then paste the contents of treasury.json here as a one-liner
# Example: TREASURY_PRIVATE_KEY=[1,2,3,...,64]
TREASURY_PRIVATE_KEY=

# MongoDB
MONGODB_URI=mongodb://localhost:27017/janamat-rewards

# Frontend
ALLOWED_ORIGINS=http://localhost:3000
